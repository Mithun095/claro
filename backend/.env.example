# Copy to .env and adjust. .env is gitignored — never commit secrets (CLAUDE.md).

# --- Stage 1: speech-to-text (faster-whisper) ---
# Model: large-v3 (best accuracy, ~3GB, slow on CPU) | medium (CPU-friendly,
# default) | small | base | tiny.
WHISPER_MODEL=medium
# If WHISPER_MODEL fails to load (e.g. too large for this machine), fall back to:
WHISPER_FALLBACK_MODEL=medium
# Device + compute type. "cpu" + "int8" is the prototype default; use "cuda" +
# "float16" if you have a GPU.
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8

# --- Stage 2: LLM (local Ollama) ---
OLLAMA_MODEL=llama3.1:8b
OLLAMA_HOST=http://localhost:11434
# Low temperature keeps the scribe faithful and low-variance.
OLLAMA_TEMPERATURE=0.2
