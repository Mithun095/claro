# Copy to .env and adjust. .env is gitignored — never commit secrets (CLAUDE.md).

# --- Stage 1: speech-to-text (faster-whisper) ---
# Model: large-v3 (best accuracy, ~3GB, slow on CPU) | medium (CPU-friendly,
# default) | small | base | tiny.
WHISPER_MODEL=medium
# If WHISPER_MODEL fails to load (e.g. too large for this machine), fall back to:
WHISPER_FALLBACK_MODEL=medium
# Live/streaming model (/ws/transcribe). Defaults to "base" for real-time speed
# on CPU — medium/large are too slow live and the transcript falls behind. Use
# "tiny" for the lowest latency, or "small" for better live accuracy on a fast
# machine. NOTE: the streaming final pass also uses this model (not WHISPER_MODEL).
# WHISPER_STREAMING_MODEL=base
#
# Streaming latency/stability tuning (all optional):
#   WHISPER_RIGHT_MARGIN_S  how long a word must "age" before it's committed
#                           (default 1.0; lower = snappier but less stable)
#   WHISPER_MIN_STEP_S      min new audio between model passes (default 0.5)
#   WHISPER_MIN_BUFFER_S    min buffered audio before transcribing (default 0.8)
#   WHISPER_VAD_THRESHOLD   VAD speech threshold 0..1 (default 0.5; raise toward
#                           0.6–0.7 to make the mic less sensitive to noise)
# Device + compute type. "cpu" + "int8" is the prototype default; use "cuda" +
# "float16" if you have a GPU.
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8

# --- Stage 2: LLM (local Ollama) ---
OLLAMA_MODEL=llama3.1:8b
OLLAMA_HOST=http://localhost:11434
# Temperature 0 keeps the scribe faithful and deterministic.
OLLAMA_TEMPERATURE=0
